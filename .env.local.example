# =============================================================================
# Replit dev environment — copy this to .env and fill in real values
# =============================================================================
#
# IMPORTANT: Use a SEPARATE Google Sheet, Drive folder and Resend test key for
# Replit dev. Do NOT use the production values here — that would let dev work
# touch your live user's data.
#
# Setup steps:
#   1. Google Cloud Console -> create new service account (or reuse existing)
#   2. Create a NEW Google Sheet for dev -> share with the service account email
#   3. Create a NEW Google Drive folder for dev -> share with the service account
#   4. Resend.com -> create a new API key (test mode is fine for dev)
# =============================================================================

# --- Google Service Account ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the full private key including BEGIN/END lines. Keep the surrounding
# quotes. Newlines should be literal \n (the app converts them at runtime).
GOOGLE_PRIVATE_KEY=""

# --- Google Sheets (dev copies, not production) ---
GOOGLE_SHEET_ID=
GOOGLE_SHEET_ID_LTD=
MASTER_SHEET_ID=

# --- Google Drive (dev folder, MUST be a Shared Drive) ---
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_OWNER_EMAIL=
GOOGLE_DRIVE_TRASH_FOLDER_ID=
GOOGLE_DRIVE_BACKUP_FOLDER_ID=

# --- Session security (any random 32+ char string for dev) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=BooksIQ Dev <onboarding@resend.dev>

# --- Admin access ---
ADMIN_EMAILS=

# --- App URL (the Replit dev URL — leave blank to auto-detect from request) ---
APP_URL=
