# Google Cloud Service Account
GOOGLE_SERVICE_ACCOUNT_EMAIL=taylor-invoices@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Sheet IDs (from URL: docs.google.com/spreadsheets/d/THIS_PART/edit)
GOOGLE_SHEET_ID=your-self-employed-sheet-id-here
GOOGLE_SHEET_ID_LTD=your-ltd-company-sheet-id-here

# Google Drive - MUST be a Shared Drive (not regular folder)
# To create: Google Drive > Shared drives > New shared drive > Add service account as Manager
# Get ID from URL: drive.google.com/drive/folders/THIS_PART
GOOGLE_DRIVE_FOLDER_ID=your-shared-drive-id-here

# Optional: Email to transfer file ownership to (for regular Drive folders)
GOOGLE_DRIVE_OWNER_EMAIL=taylor@example.com

# Optional: Trash folder ID for deleted invoice PDFs
# Create a "Trash" folder inside Taylor Invoices and get its ID from URL
# If not set, deleted PDFs go to Google's trash instead
GOOGLE_DRIVE_TRASH_FOLDER_ID=your-trash-folder-id-here
